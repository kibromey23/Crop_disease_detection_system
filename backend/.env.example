# CropGuard AI — Backend Environment Variables
# Copy this to .env and fill in your values

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/cropguard_db

# JWT — CHANGE THIS in production
JWT_SECRET=cropguard_super_secret_key_change_me_in_production_2026

# AI Model Server
AI_SERVER_URL=http://localhost:8000

# Image compression
IMAGE_COMPRESS=true
IMAGE_MAX_WIDTH=800
IMAGE_QUALITY=85
MAX_FILE_SIZE=10485760

# Sage AI Assistant (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
